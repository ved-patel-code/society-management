# --- Secrets / env (NEVER commit real values) ---
.env
*.env
!*.env.example
!*.env.template

# Local test/society credentials — never commit
*CREDENTIALS*.txt
SHARNAM_DUPLEX_CREDENTIALS.txt

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/

# --- Container volumes / data (never commit stateful dirs) ---
/data/
**/pgdata/
**/miniodata/

# --- Node / frontend (Vite + React) ---
node_modules/
frontend/dist/
frontend/dev-dist/
frontend/.vite/
frontend/.env.local
*.tsbuildinfo

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
