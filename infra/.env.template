# Copy to `.env` at the repo root and fill in real values. NEVER commit the real .env.
# docker-compose reads `.env` automatically.

# --- Postgres ---
POSTGRES_USER=society
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=society
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# SQLAlchemy URL (sync driver psycopg v3). Host = the compose service name.
DATABASE_URL=postgresql+psycopg://society:change-me-postgres@postgres:5432/society

# --- JWT / auth ---
# Generate a strong secret, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`.
# MUST be at least 32 bytes for HS256 (the app refuses to start otherwise).
JWT_SECRET=change-me-to-a-long-random-secret-min-32-bytes-abcdefghij
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14

# --- Password reset temp password lifetime ---
PASSWORD_RESET_TTL_MINUTES=60

# --- Email (test mode renders to logs; smtp wired later) ---
EMAIL_MODE=test

# --- MinIO (interface only wired now) ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_SECURE=false

# --- First super-admin (seeded by `python -m app.cli.seed`) ---
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-superadmin
SUPERADMIN_FULL_NAME=Platform Super Admin

# --- App ---
ENV=development
# Comma-separated list of allowed CORS origins (frontend built later).
CORS_ORIGINS=http://localhost:3000
